{UTF-8}
Aligned Drone Count= INTEG (Swarm Alignment Rate-Collision Loss Rate,
		0)
	~	Drones
	~		|

Collision Loss Rate=Aligned Drone Count * Obstacle Density
	~	Drones/Min
	~		|

Communication Range=50
	~	Meters
	~		|

Obstacle Density=0.02
	~	Dmnl
	~		|

Scanning Rate=Aligned Drone Count * 50
	~	{$m^2$/Min}
	~		|

Search Area Covered= INTEG (Scanning Rate,
		0)
	~	{m^2}
	~		|

Swarm Alignment Rate=(100 - Aligned Drone Count) * (Communication Range / 100)
	~	Drones/Min
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 60
	~	Minute
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Minute
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Minute [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Minute [0,?]
	~	The time step for the simulation.
	|

