{UTF-8}
AC Demand Power=(Nagpur Ambient Temperature / 45) * 2000
	~	kW
	~		|

Charging Rate=IF THEN ELSE(Grid Stability Reserve > 1000, 500, 0)
	~	kW
	~		|

EV Fleet Battery Stock= INTEG (Charging Rate-V2G Discharge Rate,
		5000)
	~	kWh
	~		|

Generation Inflow=3000
	~	kW
	~		|

Grid Consumption=1500 + AC Demand Power
	~	kW
	~		|

Grid Stability Reserve= INTEG (Generation Inflow+V2G Discharge Rate-Grid Consumption,
		1000)
	~	kWh
	~		|

Nagpur Ambient Temperature=30 + 15 * SIN(2 * 3.14159 * (Time - 9) / 24)
	~	Celsius
	~		|

V2G Discharge Rate=IF THEN ELSE(Grid Stability Reserve < 500, 200, 0)
	~	kW
	~		|

V2G Trigger=500
	~	kW
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 24
	~	Hour
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Hour
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Hour [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Hour [0,?]
	~	The time step for the simulation.
	|

