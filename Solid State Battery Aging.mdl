{UTF-8}
Battery Capacity= INTEG (-Capacity Loss Rate,
		100)
	~	Percent
	~		|

Capacity Loss Rate=(Dendrite Mass * 0.01) + (Charge Current * 0.005)
	~	Percent/Cycle
	~		|

Charge Current=2
	~	{C-Rate}
	~		|

Degradation Factor=(Operating Temperature / 25)^2
	~	Dmnl
	~		|

Dendrite Growth Rate=Charge Current * 0.001 * (Operating Temperature / 25)
	~	mg/Cycle
	~		|

Dendrite Mass= INTEG (Dendrite Growth Rate,
		0)
	~	mg
	~		|

Operating Temperature=25 + (Charge Current * 15)
	~	Celsius
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Cycle
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Cycle
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Cycle [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Cycle [0,?]
	~	The time step for the simulation.
	|

