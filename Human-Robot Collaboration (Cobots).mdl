{UTF-8}
Collision Risk=Robot Arm Speed / (Human Proximity + 0.1)
	~	Risk Index
	~		|

Finished Goods Inventory= INTEG (Production Rate,
		0)
	~	Unit
	~		|

Human Proximity=1 + SIN(2 * 3.14159 * Time / 60)
	~	Meter
	~		|

Incoming Orders=5
	~	Unit/Minute
	~		|

Production Rate=Robot Arm Speed
	~	Unit/Minute
	~		|

Robot Arm Speed=IF THEN ELSE(Human Proximity < 1, 2, 10)
	~	Unit/Minute
	~		|

Work In Progress= INTEG (Incoming Orders-Production Rate,
		50)
	~	Unit
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 480
	~	Minute
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Minute
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Minute [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Minute [0,?]
	~	The time step for the simulation.
	|

