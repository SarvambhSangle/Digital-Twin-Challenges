{UTF-8}
Carbon Tax Level=50
	~	$/Ton CO2
	~		|

Credit Generation Rate=120
	~	Credit/Month
	~		|

Credit Price=1000 / (Green Factory Credit Stock + 1)
	~	$/Credit
	~		|

Credit Purchase Rate=IF THEN ELSE(Carbon Tax Level > Credit Price, 50, 0)
	~	Credit/Month
	~		|

Debt Reduction Rate=Credit Purchase Rate
	~	Ton CO2/Month
	~		|

Emissions Rate=100
	~	Ton CO2/Month
	~		|

Green Factory Credit Stock= INTEG (Credit Generation Rate-Credit Purchase Rate,
		200)
	~	Credit
	~		|

Polluting Factory Carbon Debt= INTEG (Emissions Rate-Debt Reduction Rate,
		1000)
	~	Ton CO2
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 60
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

