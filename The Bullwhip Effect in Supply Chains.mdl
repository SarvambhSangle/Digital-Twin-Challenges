{UTF-8}
Customer Demand=10 + STEP(5, 12)
	~	Unit/Week
	~		|

Customer Sales=10 + STEP(2, 10)
	~	Unit/Week
	~		|

Distributor Inventory= INTEG (Distributor Orders-Retail Orders,
		500)
	~	Unit
	~		|

Distributor Orders=SMOOTHI(Retail Orders, Shipment Delay * 2, Retail Orders)
	~	Unit/Week
	~		|

Manufacturer Inventory= INTEG (Production Rate-Distributor Orders,
		1000)
	~	Unit
	~		|

Order Fulfillment=Retail Inventory / Shipment Delay
	~	Unit/Week
	~		|

Production Rate=DELAY3(Distributor Orders, 4)
	~	Unit/Week
	~		|

Retail Inventory= INTEG (Retail Orders-Customer Sales,
		100)
	~	Unit
	~		|

Retail Orders=SMOOTHI(Customer Sales, Shipment Delay, Customer Sales)
	~	Unit/Week
	~		|

Shipment Delay=2
	~	Week
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 52
	~	Week
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Week
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Week [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Week [0,?]
	~	The time step for the simulation.
	|

