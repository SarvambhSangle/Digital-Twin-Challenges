{UTF-8}
Evapotranspiration Rate=2 + SIN(2 * 3.14159 * Time / 24)
	~	Percent/Hour
	~		|

Irrigation Rate=Pump Capacity * Soil Moisture Sensor
	~	Percent/Hour
	~		|

Pump Capacity=10
	~	Percent/Hour
	~		|

Soil Moisture Content= INTEG (Irrigation Rate-Evapotranspiration Rate,
		40)
	~	Percent
	~		|

Soil Moisture Sensor=IF THEN ELSE(Soil Moisture Content < Target Threshold, 1, 0)
	~	Dmnl
	~		|

Target Threshold=30
	~	Percent
	~		|

Water Reservoir= INTEG (-Irrigation Rate,
		5000)
	~	Liters
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 168
	~	Hour
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Hour
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Hour [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.5
	~	Hour [0,?]
	~	The time step for the simulation.
	|

