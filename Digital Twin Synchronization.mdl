{UTF-8}
Physical Change Rate=10 + STEP(20, 30)
	~	Unit/ms
	~		|

Physical Machine State= INTEG (Physical Change Rate,
		0)
	~	Unit
	~		|

Sensor Sampling Frequency=0.1
	~	1/ms
	~		|

Sync Error=Physical Machine State-Virtual Replica State
	~	Unit
	~		|

Sync Update Rate=(Sync Error * Sensor Sampling Frequency)
	~	Unit/ms
	~		|

Virtual Replica State= INTEG (Sync Update Rate,
		0)
	~	Unit
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	ms
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	ms
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	ms [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	ms [0,?]
	~	The time step for the simulation.
	|

