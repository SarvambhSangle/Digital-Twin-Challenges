{UTF-8}
Maintenance Backlog= INTEG (Service Request Rate - Repair Rate,
		0)
	~	Task
	~		|

Maintenance Skill Level=0.8
	~	Dmnl
	~		|

Repair Rate=(Maintenance Backlog * 0.5) * Maintenance Skill Level
	~	Percent/Hour
	~		|

Robot Component Health= INTEG (Repair Rate-Wear and Tear Rate,
		100)
	~	Percent
	~		|

Service Request Rate=IF THEN ELSE(Robot Component Health < 80, 1, 0)
	~	Task/Hour
	~		|

Vibration Threshold=IF THEN ELSE(Robot Component Health < 75, 1, 0)
	~	Dmnl
	~		|

Wear and Tear Rate=0.1 * (1 + (Time / 100))
	~	Percent/Hour
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 720
	~	Hour
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Hour
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Hour [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Hour [0,?]
	~	The time step for the simulation.
	|

