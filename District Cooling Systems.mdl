{UTF-8}
Ambient Temperature=30 + 10 * SIN(2 * 3.14159 * (Time - 8) / 24)
	~	°C
	~		|

Building Heat Load=(Ambient Temperature - 22) * 20
	~	Tons
	~		|

Chiller Production Rate=IF THEN ELSE(Time < 6 :OR: Time > 20, 150, 50)
	~	Tons
	~		|

Cooling Efficiency Gain=1.3
	~	Dmnl
	~		|

District Thermal Storage= INTEG (Chiller Production Rate-Building Heat Load,
		500)
	~	{Ton-Hours}
	~		|

Electricity Demand=Chiller Production Rate / Cooling Efficiency Gain
	~	kW
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 24
	~	Hour
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Hour
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Hour [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.5
	~	Hour [0,?]
	~	The time step for the simulation.
	|

