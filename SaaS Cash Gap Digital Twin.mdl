{UTF-8}
Burn Rate=10000 + ("CAC (Customer Acquisition Cost)")
	~	Dollar/Month
	~		|

"CAC (Customer Acquisition Cost)"=500
	~	Dollar/User
	~		|

Cash= INTEG (Revenue Inflow-Burn Rate,
		50000)
	~	Dollar
	~		|

Cash Collected=Revenue Inflow * 1.2
	~	Dollar/Month
	~		|

Customer Acquisition Rate=Marketing Budget / "CAC (Customer Acquisition Cost)"
	~	User/Month
	~		|

Customer Base= INTEG (Customer Acquisition Rate,
		0)
	~	User
	~		|

Deferred Revenue= INTEG (Cash Collected - Revenue Recognized,
		0)
	~	Dollar
	~		|

Marketing Budget=5000
	~	Dollar/Month
	~		|

Monthly Subscription Fee=50
	~	Dollar/User/Month
	~		|

Revenue Inflow=Customer Base * Monthly Subscription Fee
	~	Dollar/Month
	~		|

Revenue Recognized=DELAY1(Cash Collected, 12)
	~	Dollar/Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 36
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Month [0,?]
	~	The time step for the simulation.
	|

