{UTF-8}
Detected Intrusion Count= INTEG (Intrusion Detection Rate,
		0)
	~	Events
	~		|

Eavesdropper Presence=STEP(1, 40) - STEP(1, 60)
	~	Dmnl
	~		|

Intrusion Detection Rate=IF THEN ELSE("Quantum Bit Error Rate (QBER)" > 0.1, 1, 0)
	~	Events/Second
	~		|

Key Generation Rate=IF THEN ELSE("Quantum Bit Error Rate (QBER)" > 0.1, 0, 100)
	~	Bits/Second
	~		|

"Quantum Bit Error Rate (QBER)"=0.02 + (Eavesdropper Presence * 0.25)
	~	Dmnl
	~		|

Secure Key Reservoir= INTEG (Key Generation Rate,
		0)
	~	Bits
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Second
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Second
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Second [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.5
	~	Second [0,?]
	~	The time step for the simulation.
	|

