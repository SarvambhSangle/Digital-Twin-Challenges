{UTF-8}
Flash Flood Indicator=IF THEN ELSE(Surface Runoff Volume > 100, 1, 0)
	~	Dmnl
	~		|

Monsoon Rainfall Rate=STEP(500, 10) - STEP(500, 40)
	~	Liters/Min
	~		|

Pavement Infiltration Rate=Surface Runoff Volume * Pavement Porosity
	~	Liters/Min
	~		|

Pavement Porosity=0.4
	~	Dmnl
	~		|

Sewer Discharge Rate=Sewer System Capacity * 0.1
	~	Liters/Min
	~		|

Sewer System Capacity= INTEG (Pavement Infiltration Rate-Sewer Discharge Rate,
		0)
	~	Liters
	~		|

Surface Runoff Volume= INTEG (Monsoon Rainfall Rate-Pavement Infiltration Rate,
		0)
	~	Liters
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 120
	~	Minute
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Minute
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Minute [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Minute [0,?]
	~	The time step for the simulation.
	|

