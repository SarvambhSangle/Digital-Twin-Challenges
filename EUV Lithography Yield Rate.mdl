{UTF-8}
Chip Production Rate=1000 * Yield Percentage
	~	Chips/Wafer
	~		|

Cumulative Defects= INTEG (Defect Generation Rate,
		0)
	~	Chips
	~		|

Defect Generation Rate=1000 * (1 - Yield Percentage)
	~	Chips/Wafer
	~		|

Mirror Reflectivity=0.7
	~	Dmnl
	~		|

Total Functional Chips= INTEG (Chip Production Rate,
		0)
	~	Chips
	~		|

Vibration Interference=RANDOM NORMAL(0, 0.2, 0.05, 0.05, 1)
	~	Dmnl
	~		|

Yield Percentage=MAX(0, (Mirror Reflectivity - Vibration Interference))
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Wafer
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Wafer
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Wafer [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Wafer [0,?]
	~	The time step for the simulation.
	|

