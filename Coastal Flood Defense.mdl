{UTF-8}
Annual Sea Rise=0.5 * (1 + (Time / 50))
	~	cm/Year
	~		|

Defense Construction Rate=IF THEN ELSE(Flood Risk > 0, 2, 0)
	~	cm/Year
	~		|

Flood Risk=MAX(0, Global Sea Level - Sea Wall Height)
	~	cm
	~		|

Global Sea Level= INTEG (Annual Sea Rise,
		0)
	~	cm
	~		|

Sea Wall Height= INTEG (Defense Construction Rate,
		50)
	~	cm
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Year [0,?]
	~	The time step for the simulation.
	|

