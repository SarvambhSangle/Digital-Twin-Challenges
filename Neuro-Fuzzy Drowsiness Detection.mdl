{UTF-8}
Arousal Recovery Rate=IF THEN ELSE(Driver Alertness Level < 40, 30, 0)
	~	Percent/Min
	~		|

Driver Alertness Level= INTEG (Arousal Recovery Rate-Fatigue Accumulation Rate,
		100)
	~	Percent
	~		|

Fatigue Accumulation Rate=("PERCLOS (Percentage of Eye Closure)" * 2) + (Steering Variance\
		 * 0.5)
	~	Percent/Min
	~		|

"PERCLOS (Percentage of Eye Closure)"=IF THEN ELSE(Time > 200, 5, 1)
	~	Dmnl
	~		|

Steering Variance=RANDOM UNIFORM(0, 10, 0)
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 480
	~	Minute
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Minute
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Minute [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Minute [0,?]
	~	The time step for the simulation.
	|

