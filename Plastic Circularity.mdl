{UTF-8}
Consumer Plastic Stock= INTEG (Production Rate-Recycling Collection Rate-Leakage Rate\
		,
		1000)
	~	Tons
	~		|

Environmental Waste= INTEG (Leakage Rate,
		0)
	~	Tons
	~		|

Leakage Rate=Consumer Plastic Stock * (1 - Recycling Efficiency)
	~	Tons/Month
	~		|

Production Rate=500 / Virgin Material Tax
	~	Tons/Month
	~		|

Recycled Material Inventory= INTEG (Leakage Rate+Recycling Collection Rate,
		0)
	~	Tons
	~		|

Recycling Collection Rate=Consumer Plastic Stock * Recycling Efficiency
	~	Tons/Month
	~		|

Recycling Efficiency=0.4
	~	Dmnl
	~		|

Virgin Material Tax=1.5
	~	$/kg
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 120
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

