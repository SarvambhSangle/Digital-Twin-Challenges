{UTF-8}
Discard Rate=10 + STEP(20, 10)
	~	Tons/Year
	~		|

"Global E-Waste Pile"= INTEG (Discard Rate-Urban Mining Rate,
		100)
	~	Tons
	~		|

Recycling Subsidy=1.5
	~	Dmnl
	~		|

Relative Cost Factor=10 / Virgin Ore Grade
	~	Dmnl
	~		|

Total Resource Supply= INTEG (Urban Mining Rate+Virgin Mining Rate,
		0)
	~	Tons
	~		|

Urban Mining Rate="Global E-Waste Pile" * 0.1 * Recycling Subsidy
	~	Tons/Year
	~		|

Virgin Mining Rate=50 / Relative Cost Factor
	~	Tons/Year
	~		|

Virgin Ore Grade=10 - (Total Resource Supply * 0.01)
	~	Percent
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 50
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Year [0,?]
	~	The time step for the simulation.
	|

