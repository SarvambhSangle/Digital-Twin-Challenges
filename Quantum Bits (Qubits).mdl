{UTF-8}
Cryogenic Cooling Factor=0.005 / Environmental Noise Level
	~	Dmnl
	~		|

Decoherence Rate=Qubit Coherence Level * Environmental Noise Level * (1 - Cryogenic Cooling Factor\
		)
	~	1/Microsecond
	~		|

Environmental Noise Level=0.1
	~	Dmnl
	~		|

Qubit Coherence Level= INTEG (-Decoherence Rate,
		1)
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 500
	~	Microsecond
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Microsecond
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Microsecond [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Microsecond [0,?]
	~	The time step for the simulation.
	|

