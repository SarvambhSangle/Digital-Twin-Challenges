{UTF-8}
Ambient Temperature=25
	~	Celsius
	~		|

Cooling Coefficient=0.2
	~	Celsius
	~		|

Cooling Rate=(Stack Temperature - Ambient Temperature) * Cooling Coefficient
	~	Celsius/Hour
	~		|

Electrolysis Rate=Solar Energy Buffer * Electrolyzer Efficiency
	~	kg H2/Hour
	~		|

Electrolyzer Efficiency=MAX(0.01, 0.7 * (1 - Thermal Loss))
	~	Dmnl
	~		|

Hydrogen Export=STEP(50, 12)
	~	kg H2/Hour
	~		|

Hydrogen Storage Tank= INTEG (Electrolysis Rate-Hydrogen Export,
		0)
	~	kg H2
	~		|

Solar Energy Buffer= INTEG (Solar Inflow-Electrolysis Rate,
		0)
	~	kWh
	~		|

Solar Inflow=MAX(0, 1000 * SIN(2 * 3.14159 * Time / 24))
	~	kW
	~		|

Stack Temperature=INTEG(Electrolysis Rate * 0.5 - Cooling Rate, 25)
	~	Celsius
	~		|

Thermal Loss=(Stack Temperature - 25) / 100
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 48
	~	Hour
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Hour
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Hour [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Hour [0,?]
	~	The time step for the simulation.
	|

