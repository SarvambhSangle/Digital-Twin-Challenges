{UTF-8}
Campus Battery Bank= INTEG (Grid Import+Solar Inflow-Campus Consumption,
		2000)
	~	kWh
	~		|

Campus Consumption=Normal Consumption * IF THEN ELSE(Main Grid Connection = 0, Critical Load Percentage\
		, 1)
	~	kW
	~		|

Critical Load Percentage=0.4
	~	Dmnl
	~		|

Grid Failure Trigger=STEP(1, 12)
	~	Dmnl
	~		|

Grid Import=IF THEN ELSE(Main Grid Connection = 1, 500, 0)
	~	kW
	~		|

Island State=IF THEN ELSE(Main Grid Connection = 0, 1, 0)
	~	Dmnl
	~		|

Main Grid Connection=1 - Grid Failure Trigger
	~	Dmnl
	~		|

Normal Consumption=800
	~	kW
	~		|

Solar Inflow=MAX(0, 500 * SIN(2 * 3.14159 * Time / 24))
	~	kW
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 48
	~	Hour
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Hour
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Hour [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Hour [0,?]
	~	The time step for the simulation.
	|

