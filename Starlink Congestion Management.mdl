{UTF-8}
Active User Connections= INTEG (Handover Success Rate-Connection Drop Rate,
		0)
	~	Users
	~		|

Congestion Factor=Active User Connections / 2000
	~	Dmnl
	~		|

Connection Drop Rate=Active User Connections * 0.1
	~	Users/Min
	~		|

Connection Request Rate=STEP(500, 10) + RANDOM NORMAL(0, 100, 50, 20, 1)
	~	Users/Min
	~		|

Handover Delay=(Active User Connections / Satellite Bandwidth Capacity) * 5
	~	Seconds
	~		|

Handover Success Rate=MAX(0, Request Buffer Queue * (1 - Congestion Factor))
	~	Users/Min
	~		|

Request Buffer Queue= INTEG (Connection Request Rate-Handover Success Rate,
		0)
	~	Users
	~		|

Satellite Bandwidth Capacity=2000
	~	Users
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 60
	~	Minute
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Minute
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Minute [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.5
	~	Minute [0,?]
	~	The time step for the simulation.
	|

