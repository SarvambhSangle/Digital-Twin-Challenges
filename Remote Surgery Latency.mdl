{UTF-8}
Command Rate=5 * SIN(2 * 3.14159 * Time / 500)
	~	mm/ms
	~		|

Network Lag=10
	~	ms
	~		|

Position Error=ABS(Surgeon Hand Position - Robotic Scalpel Position)
	~	mm
	~		|

Remote Execution Rate=DELAY FIXED(Command Rate, Network Lag, 0)
	~	mm/ms
	~		|

Robotic Scalpel Position= INTEG (Remote Execution Rate,
		0)
	~	mm
	~		|

Safety Alarm=IF THEN ELSE(Position Error > 2, 1, 0)
	~	Dmnl
	~		|

Surgeon Hand Position= INTEG (Command Rate,
		0)
	~	mm
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 1000
	~	ms
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	ms
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	ms [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	ms [0,?]
	~	The time step for the simulation.
	|

