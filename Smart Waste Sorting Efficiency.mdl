{UTF-8}
AI Training Data Pool= INTEG (Data Acquisition Rate,
		100)
	~	GB
	~		|

Automated Sorting Rate=100 * Sorting Accuracy
	~	Tons/Week
	~		|

Data Acquisition Rate="High-Purity Plastic Stock" * 10
	~	GB/Week
	~		|

"High-Purity Plastic Stock"= INTEG (Automated Sorting Rate,
		0)
	~	Tons
	~		|

Sorting Accuracy=0.6 + (0.3 * (AI Training Data Pool / 10000))
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 52
	~	Week
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Week
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Week [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Week [0,?]
	~	The time step for the simulation.
	|

