{UTF-8}
Consumer Purchase Rate=100 + STEP(20, 10)
	~	Units/Week
	~		|

Demand Signal Noise=STEP(20, 10) * RANDOM NORMAL(-0.5, 0.5, 0, 0.2, 1)
	~	Units/Week
	~		|

Distributor Backlog= INTEG (Order Placement Rate+Wafer Start Rate,
		2000)
	~	Units
	~		|

Fab Lead Time=16
	~	Weeks
	~		|

Fab Work In Progress= INTEG (Order Placement Rate+Wafer Start Rate,
		5000)
	~	Units
	~		|

Order Placement Rate=Consumer Purchase Rate + (Safety Stock Target - Retail Chip Inventory\
		)
	~	Units/Week
	~		|

Retail Chip Inventory= INTEG (-Consumer Purchase Rate-Order Placement Rate,
		1000)
	~	Units
	~		|

Safety Stock Target=1200
	~	Units
	~		|

Wafer Start Rate=DELAY FIXED(Order Placement Rate, 16, Order Placement Rate)
	~	Units/Week
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 52
	~	Week
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Week
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Week [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Week [0,?]
	~	The time step for the simulation.
	|

