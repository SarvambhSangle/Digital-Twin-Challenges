{UTF-8}
Active Satellites= INTEG (Satellite Launch Rate-Collision Rate,
		1000)
	~	Sats
	~		|

Collision Rate=(Active Satellites * Orbital Debris Pieces) * 1e-07
	~	Sats/Year
	~		|

Debris Decay Rate=Orbital Debris Pieces * 0.05
	~	Pieces/Year
	~		|

Fragmentation Factor=1000
	~	Pieces/Sat
	~		|

Orbital Debris Pieces= INTEG ((Collision Rate * Fragmentation Factor) - Debris Decay Rate\
		,
		 5000)
	~	Pieces
	~		|

Probability of Strike=Orbital Debris Pieces / 1e+06
	~	Dmnl
	~		|

Satellite Launch Rate=50 + STEP(100, 10)
	~	Sats/Year
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 50
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Year [0,?]
	~	The time step for the simulation.
	|

